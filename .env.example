# Postgres container credentials (consumed by the `db` service)
POSTGRES_USER=foryou
POSTGRES_PASSWORD=foryou
POSTGRES_DB=foryou

# Application database URL (async driver, used by the app / ranking service)
DATABASE_URL=postgresql+asyncpg://foryou:foryou@db:5432/foryou

# Alembic database URL (sync driver, used only to run migrations)
ALEMBIC_DATABASE_URL=postgresql+psycopg://foryou:foryou@db:5432/foryou

# Web layer (plan.md §9). Browser origins the ranking API accepts, as a JSON array.
# Defaults to the Vite dev server if unset; uncomment to override.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Host port for the `api` service (container port stays 8000). Set this if 8000 is
# already in use on your machine; the frontend follows it automatically.
# API_PORT=8000
