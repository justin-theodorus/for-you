# Postgres container credentials (consumed by the `db` service)
POSTGRES_USER=foryou
POSTGRES_PASSWORD=foryou
POSTGRES_DB=foryou

# Application database URL (async driver, used by the app / ranking service)
DATABASE_URL=postgresql+asyncpg://foryou:foryou@db:5432/foryou

# Alembic database URL (sync driver, used only to run migrations)
ALEMBIC_DATABASE_URL=postgresql+psycopg://foryou:foryou@db:5432/foryou

# LLM persona agents (plan.md §6) and the live-trigger path (plan.md §8). Set to generate
# real LLM content via `make personas` / `make live` and the web composer; leave unset to use
# the deterministic offline FakeLLM (no API calls, no cost).
# OPENAI_API_KEY=sk-...

# Live-trigger path (plan.md §8). A real user's post may trigger a few persona replies. Cost
# is hard-capped: a fixed number per action, plus global daily token/reaction counters in
# budget_ledger that short-circuit to "no new reaction" once spent. The daily caps key on the
# real UTC date (they cap real money), not the simulated world clock. Defaults shown.
# LIVE_ENABLED=true
# LIVE_MAX_REACTIONS_PER_ACTION=3
# LIVE_DAILY_REACTION_CAP=40
# LIVE_DAILY_TOKEN_CAP=50000

# Web layer (plan.md §9). Browser origins the ranking API accepts, as a JSON array.
# Defaults to the Vite dev server if unset; uncomment to override.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Host port for the `api` service (container port stays 8000). Set this if 8000 is
# already in use on your machine; the frontend follows it automatically.
# API_PORT=8000
